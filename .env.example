# ---------------------------------------------------------------------------
# Data Analysis Chat Assistant — example configuration.
# Copy to `.env` and fill in the required values:  cp .env.example .env
# Every variable is loaded and validated at startup by src/assistant/config.py.
# ---------------------------------------------------------------------------

# --- Required credentials -------------------------------------------------
# Free Gemini API key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GCP project used for BigQuery billing (the public dataset is free to query).
GOOGLE_CLOUD_PROJECT=

# --- BigQuery -------------------------------------------------------------
BQ_DATASET=bigquery-public-data.thelook_ecommerce
MAX_BYTES_BILLED=2000000000          # ~2 GB dry-run cost guard per query
SQL_MAX_LIMIT=1000                   # LIMIT injected/clamped by the SQL validator

# --- Models ---------------------------------------------------------------
LLM_MODEL=gemini-3.1-flash-lite      # main model: SQL + report generation (quality-critical)
LLM_MODEL_CHEAP=gemini-2.5-flash-lite   # cheaper model for low-stakes structured calls (intent/contextualize/decompose/prefs/parse)
EMBEDDING_MODEL=models/gemini-embedding-001   # 3072-dim; used by the Golden Bucket

# --- Agent behavior -------------------------------------------------------
MAX_SQL_ATTEMPTS=3                   # bounded SQL self-correction loop
CONTEXTUALIZE_CONFIDENCE_FLOOR=0.6   # below this, clarify instead of guessing
MAX_SUB_QUESTIONS=4                  # compound-question fan-out cap (cost guard)
MAX_HISTORY_MESSAGES=10              # turns of history fed to contextualization

# --- Resilience (retries + circuit breaker for Gemini / BigQuery) ---------
LLM_MAX_RETRIES=4                    # tenacity attempts on transient errors (also used for BigQuery)
LLM_RETRY_BASE_DELAY=1.0             # exponential-backoff base delay (seconds)
CIRCUIT_BREAKER_THRESHOLD=5          # consecutive failures before the breaker opens
CIRCUIT_BREAKER_COOLDOWN_SECONDS=30  # cool-down before the breaker half-opens to probe

# --- Golden Bucket (Hybrid Intelligence) ----------------------------------
GOLDEN_TOP_K=3                       # how many analyst Trios to retrieve per question
GOLDEN_SIM_FLOOR=0.68                # minimum cosine similarity to inject a Trio
GOLDEN_TRIOS_DIR=data/golden_trios   # source Trio JSON files
GOLDEN_INDEX_DIR=data/golden_index   # built embedding index (rebuilt by `make ingest`)

# --- Learning loop (automatic Trio promotion: metrics + dedup + LLM-judge) -
LEARNING_LOOP_ENABLED=true            # auto-promote good, novel turns in the background
LEARNING_DEDUP_SIMILARITY=0.97        # skip promotion only if a near-identical Trio exists (in-domain Qs share high baseline similarity)
LEARNING_FAITHFULNESS_BAR=4           # min LLM-judge faithfulness score (0-5) to promote
LEARNING_INTENT_BAR=4                 # min LLM-judge intent-satisfaction (0-5): don't learn incomplete answers
LEARNING_MAX_ATTEMPTS=2               # max self-corrections a turn may have used and still be learnable

# --- Identity & persona ---------------------------------------------------
DEFAULT_PERSONA=concise_exec         # active org persona (concise_exec | data_storyteller)
DEFAULT_USER=manager_a               # CLI identity when --user is not passed
PERSONAS_DIR=data/personas           # persona YAMLs (hot-reloaded on edit)
APP_DB_PATH=data/app.db              # SQLite store: user preferences, saved reports, audit log
SEED_REPORTS_DIR=data/seed_reports   # seed Saved Reports loaded on first run (oversight demo)

# --- PII masking ----------------------------------------------------------
PII_MASK_COLUMNS=email,street_address,postal_code,latitude,longitude,user_geom
PII_MASK_STYLE=partial               # partial | redact

# --- Observability --------------------------------------------------------
LANGSMITH_API_KEY=                   # optional; enables LangSmith auto-tracing when set
LOG_LEVEL=INFO
TRACES_DIR=traces                    # per-turn run-trace JSON files (/trace shows the last)
LOGS_DIR=logs                        # structured JSON logs (logs/agent.jsonl)
